<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_root"
    android:layout_width="match_height"
    android:layout_height="match_parent"
    android:adjustViewBounds="true"
    android:background="@drawable/widget_bg_shape"
    android:padding="16dp">

    <!-- Top Left Header: City and Condition description -->
    <LinearLayout
        android:id="@+id/header_layout"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_alignParentStart="true"
        android:layout_alignParentTop="true"
        android:orientation="vertical">

        <TextView
            android:id="@+id/widget_city"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:ellipsize="end"
            android:maxLines="1"
            android:text="DKI Jakarta"
            android:textColor="#FFFFFF"
            android:textSize="16sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/widget_condition"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Mostly Sunny"
            android:textColor="#93C5FD"
            android:textSize="11sp" />
    </LinearLayout>

    <!-- Top Right Header: Large Emoji icon -->
    <TextView
        android:id="@+id/widget_emoji"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_alignParentEnd="true"
        android:layout_alignParentTop="true"
        android:text="☀️"
        android:textSize="32sp" />

    <!-- Center Left / Main Area: Temperature Display -->
    <TextView
        android:id="@+id/widget_temp"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_alignParentStart="true"
        android:layout_centerInParent="true"
        android:layout_marginTop="8dp"
        android:text="28.5°C"
        android:textColor="#FFFFFF"
        android:textSize="32sp"
        android:textStyle="bold" />

    <!-- Bottom Metadata row -->
    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true">

        <!-- Metrics display slots (Slot 1 and Slot 2) -->
        <LinearLayout
            android:id="@+id/metrics_layout"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignParentStart="true"
            android:layout_centerVertical="true"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/widget_tag1"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/widget_tag_bg"
                android:paddingHorizontal="6dp"
                android:paddingVertical="3dp"
                android:textColor="#FFFFFF"
                android:textSize="9sp"
                android:text="💨 12 km/h"
                android:layout_marginEnd="6dp" />

            <TextView
                android:id="@+id/widget_tag2"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/widget_tag_bg"
                android:paddingHorizontal="6dp"
                android:paddingVertical="3dp"
                android:textColor="#FFFFFF"
                android:textSize="9sp"
                android:text="💧 72% RH" />
        </LinearLayout>

        <!-- Dynamic refreshed time -->
        <TextView
            android:id="@+id/widget_refreshed_time"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignParentEnd="true"
            android:layout_centerVertical="true"
            android:text="Refreshed 13:00"
            android:textColor="#80FFFFFF"
            android:textSize="8sp" />

    </RelativeLayout>
</RelativeLayout>
